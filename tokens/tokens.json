{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "brand": "UniMate AI / 牛小匠课代表",
    "version": "0.1.0",
    "owner": "JR Academy",
    "lastUpdated": "2026-05-11"
  },
  "color": {
    "brand": {
      "coral":     { "value": "#FF7A66", "usage": "Main CTA, AI study actions, Deadline/紧迫" },
      "bubblegum": { "value": "#FF6BA9", "usage": "Quiz, achievement, fun states" },
      "sunshine":  { "value": "#FFD43B", "usage": "Reward, upgrade, XP" },
      "mint":      { "value": "#3DD9A9", "usage": "Progress, completed, success" },
      "purple":    { "value": "#8B5CF6", "usage": "AI generation, smart features, Premium" }
    },
    "neutral": {
      "ink":      { "value": "#1F1B2D", "usage": "Primary headings" },
      "inkSoft":  { "value": "#3D3851", "usage": "Body emphasis" },
      "slate":    { "value": "#6B6478", "usage": "Secondary body" },
      "stone":    { "value": "#C7C0D5", "usage": "Divider / disabled" },
      "hairline": { "value": "#EFE8DA", "usage": "Soft border" },
      "canvas":   { "value": "#FFFEF7", "usage": "🚨 Main page background — NEVER use #FFFFFF" },
      "white":    { "value": "#FFFFFF", "usage": "Cards / Modals" }
    },
    "wash": {
      "coral":     { "value": "#FFEFE9" },
      "bubblegum": { "value": "#FFEAF3" },
      "sunshine":  { "value": "#FFF7D6" },
      "mint":      { "value": "#DCF6EC" },
      "purple":    { "value": "#F1EAFF" }
    },
    "gradient": {
      "coral":     { "value": "linear-gradient(135deg, #FF9A80 0%, #FF5B7E 100%)" },
      "bubblegum": { "value": "linear-gradient(135deg, #FF8FBE 0%, #FF4F8F 100%)" },
      "sunshine":  { "value": "linear-gradient(135deg, #FFE26B 0%, #FFB638 100%)" },
      "mint":      { "value": "linear-gradient(135deg, #6BE7BF 0%, #1FC692 100%)" },
      "purple":    { "value": "linear-gradient(135deg, #A78BFA 0%, #7C3AED 100%)" }
    }
  },
  "radius": {
    "xs":   { "value": "4px",    "usage": "micro chip" },
    "sm":   { "value": "8px",    "usage": "small control" },
    "md":   { "value": "12px",   "usage": "input" },
    "lg":   { "value": "24px",   "usage": "card (default)" },
    "xl":   { "value": "40px",   "usage": "feature card / hero panel" },
    "full": { "value": "9999px", "usage": "button / badge / pill" }
  },
  "spacing": {
    "1":  { "value": "4px"  },
    "2":  { "value": "8px"  },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" },
    "20": { "value": "80px" }
  },
  "shadow": {
    "sm":      { "value": "0 2px 8px rgba(31,27,45,0.06)",   "usage": "input / chip" },
    "md":      { "value": "0 8px 24px rgba(31,27,45,0.08)",  "usage": "card" },
    "lg":      { "value": "0 16px 40px rgba(31,27,45,0.12)", "usage": "modal / hero" },
    "coral":   { "value": "0 12px 28px rgba(255,122,102,0.32)" },
    "mint":    { "value": "0 12px 28px rgba(61,217,169,0.28)" },
    "purple":  { "value": "0 12px 28px rgba(139,92,246,0.32)" },
    "sticker": { "value": "4px 4px 0 rgba(31,27,45,0.95)",  "usage": "ONLY for sticker badges" }
  },
  "font": {
    "family": {
      "sans":   { "value": "'Plus Jakarta Sans', 'PingFang SC', 'HarmonyOS Sans SC', 'Microsoft YaHei', system-ui, sans-serif" },
      "accent": { "value": "'Caveat', cursive", "usage": "ONLY for short encouragement notes" }
    },
    "size": {
      "hero":    { "value": "72px" },
      "page":    { "value": "48px" },
      "section": { "value": "36px" },
      "card":    { "value": "20px" },
      "bodyLg":  { "value": "18px" },
      "body":    { "value": "16px" },
      "bodySm":  { "value": "14px" },
      "caption": { "value": "12px" },
      "button":  { "value": "15px" },
      "eyebrow": { "value": "12px" }
    },
    "weight": {
      "regular":  { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" },
      "extrabold": { "value": "800" }
    },
    "lineHeight": {
      "tight":   { "value": "1.15" },
      "snug":    { "value": "1.3"  },
      "normal":  { "value": "1.5"  },
      "relaxed": { "value": "1.7"  }
    }
  },
  "motion": {
    "duration": {
      "press":  { "value": "120ms" },
      "hover":  { "value": "180ms" },
      "card":   { "value": "200ms" },
      "modal":  { "value": "260ms" },
      "mascot": { "value": "400ms" },
      "blob":   { "value": "7s"    }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0.8, 0.2, 1)" },
      "spring":   { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
    }
  },
  "mascot": {
    "states": [
      "default", "happy", "studying", "thinking",
      "ai-analyzing", "charging", "tired", "deadline", "champion"
    ]
  },
  "featureColorMap": {
    "lecture":         { "color": "purple",    "wash": "purple",    "mood": "studying" },
    "quiz":            { "color": "bubblegum", "wash": "bubblegum", "mood": "champion" },
    "essay":           { "color": "sunshine",  "wash": "sunshine",  "mood": "studying" },
    "assignment":      { "color": "coral",     "wash": "coral",     "mood": "deadline" },
    "study-planner":   { "color": "mint",      "wash": "mint",      "mood": "happy" },
    "ai-chat":         { "color": "purple",    "wash": "purple",    "mood": "thinking" },
    "career":          { "color": "purple",    "wash": "purple",    "mood": "champion" },
    "xp-reward":       { "color": "sunshine",  "wash": "sunshine",  "mood": "champion" }
  }
}
